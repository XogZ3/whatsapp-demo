---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Bookd - WhatsApp Salon Booking" description="Turn WhatsApp messages into confirmed appointments. Zero commission booking for salons.">
  <main class="min-h-screen flex items-center justify-center">
    <div class="text-center max-w-2xl mx-auto px-4">
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 mb-6">
        Your customers already message you on WhatsApp.
        <span class="text-emerald-600"> Bookd turns those messages into confirmed appointments.</span>
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        WhatsApp-native salon booking. Zero commission. Setup in minutes.
      </p>
      <a
        href="https://wa.me/1234567890?text=Hi"
        class="inline-flex items-center gap-2 bg-emerald-600 text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-emerald-700 transition-colors"
      >
        Try the Demo
      </a>
    </div>
  </main>
</Layout>
