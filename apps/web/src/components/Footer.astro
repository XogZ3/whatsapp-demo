---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-100 bg-gray-50">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-4">
      <div>
        <div class="flex items-center gap-2">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-600 text-sm font-bold text-white">B</div>
          <span class="text-xl font-bold text-gray-900">Bookd</span>
        </div>
        <p class="mt-3 text-sm text-gray-500">
          WhatsApp-native booking for salons. Built by <a href="#" class="text-emerald-600 hover:underline">Savi</a>.
        </p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-900">Product</h3>
        <ul class="mt-3 space-y-2">
          <li><a href="/pricing" class="text-sm text-gray-500 hover:text-gray-900">Pricing</a></li>
          <li><a href="/demo" class="text-sm text-gray-500 hover:text-gray-900">Demo</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-900">Use Cases</h3>
        <ul class="mt-3 space-y-2">
          <li><a href="#" class="text-sm text-gray-500 hover:text-gray-900">Salons</a></li>
          <li><a href="#" class="text-sm text-gray-500 hover:text-gray-900">Barbershops</a></li>
          <li><a href="#" class="text-sm text-gray-500 hover:text-gray-900">Spas</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-900">Company</h3>
        <ul class="mt-3 space-y-2">
          <li><a href="#" class="text-sm text-gray-500 hover:text-gray-900">About Savi</a></li>
          <li><a href="#" class="text-sm text-gray-500 hover:text-gray-900">Privacy</a></li>
          <li><a href="#" class="text-sm text-gray-500 hover:text-gray-900">Terms</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-8 border-t border-gray-200 pt-6 text-center text-sm text-gray-400">
      &copy; {year} Savi Agency. All rights reserved.
    </div>
  </div>
</footer>
