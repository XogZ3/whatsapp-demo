---
import Layout from "../../layouts/Layout.astro";

const plans = [
  {
    name: "Starter",
    price: "49",
    desc: "Perfect for solo stylists and freelancers",
    features: [
      { text: "1 stylist", included: true },
      { text: "Up to 100 bookings/month", included: true },
      { text: "WhatsApp booking bot", included: true },
      { text: "Automated reminders (48h + 2h)", included: true },
      { text: "Message deduplication", included: true },
      { text: "Returning customer memory", included: false },
      { text: "Multi-language support", included: false },
      { text: "Priority support", included: false },
      { text: "Dedicated account manager", included: false },
    ],
  },
  {
    name: "Growth",
    price: "79",
    desc: "For growing salons with a small team",
    popular: true,
    features: [
      { text: "Up to 5 stylists", included: true },
      { text: "Unlimited bookings", included: true },
      { text: "WhatsApp booking bot", included: true },
      { text: "Automated reminders (48h + 2h)", included: true },
      { text: "Message deduplication", included: true },
      { text: "Returning customer memory", included: true },
      { text: "Multi-language support", included: false },
      { text: "Priority support", included: true },
      { text: "Dedicated account manager", included: false },
    ],
  },
  {
    name: "Scale",
    price: "99",
    desc: "For established salons and multi-location",
    features: [
      { text: "Unlimited stylists", included: true },
      { text: "Unlimited bookings", included: true },
      { text: "WhatsApp booking bot", included: true },
      { text: "Automated reminders (48h + 2h)", included: true },
      { text: "Message deduplication", included: true },
      { text: "Returning customer memory", included: true },
      { text: "Multi-language (EN/AR/DE)", included: true },
      { text: "Priority support", included: true },
      { text: "Dedicated account manager", included: true },
    ],
  },
];
---

<Layout title="Pricing - Bookd" description="Simple, transparent pricing for WhatsApp salon booking. No commission, no per-booking fees.">
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-bold text-gray-900 sm:text-5xl">Simple, transparent pricing</h1>
        <p class="mx-auto mt-4 max-w-xl text-lg text-gray-500">
          No commission. No per-booking fees. No hidden costs. Just a flat monthly rate.
        </p>
      </div>

      <div class="mt-16 grid gap-8 lg:grid-cols-3">
        {plans.map((plan) => (
          <div class={`rounded-2xl border bg-white p-8 shadow-sm ${plan.popular ? "border-emerald-500 ring-2 ring-emerald-500" : "border-gray-200"}`}>
            {plan.popular && (
              <div class="mb-4 inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">
                Most popular
              </div>
            )}
            <h2 class="text-2xl font-bold text-gray-900">{plan.name}</h2>
            <p class="mt-1 text-sm text-gray-500">{plan.desc}</p>
            <div class="mt-6">
              <span class="text-5xl font-bold text-gray-900">EUR {plan.price}</span>
              <span class="text-gray-500">/month</span>
            </div>
            <a
              href="https://wa.me/1234567890?text=Hi"
              class={`mt-8 block w-full rounded-full py-3 text-center text-sm font-semibold transition-colors ${
                plan.popular
                  ? "bg-emerald-600 text-white hover:bg-emerald-700"
                  : "border border-gray-300 bg-white text-gray-700 hover:bg-gray-50"
              }`}
            >
              Get started
            </a>
            <ul class="mt-8 space-y-3">
              {plan.features.map((f) => (
                <li class="flex items-center gap-3 text-sm">
                  {f.included ? (
                    <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  ) : (
                    <svg class="h-5 w-5 flex-shrink-0 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                  )}
                  <span class={f.included ? "text-gray-700" : "text-gray-400"}>{f.text}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Comparison callout -->
      <div class="mt-16 rounded-2xl bg-emerald-50 p-8 text-center">
        <h3 class="text-xl font-bold text-gray-900">Compare with competitors</h3>
        <div class="mt-6 overflow-x-auto">
          <table class="mx-auto text-left text-sm">
            <thead>
              <tr class="border-b border-emerald-200">
                <th class="px-4 py-3 font-semibold text-gray-900"></th>
                <th class="px-4 py-3 font-semibold text-emerald-700">Bookd</th>
                <th class="px-4 py-3 font-semibold text-gray-500">Treatwell</th>
                <th class="px-4 py-3 font-semibold text-gray-500">Fresha</th>
                <th class="px-4 py-3 font-semibold text-gray-500">Booksy</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-emerald-100">
              <tr>
                <td class="px-4 py-3 font-medium text-gray-700">Commission</td>
                <td class="px-4 py-3 font-bold text-emerald-700">0%</td>
                <td class="px-4 py-3 text-gray-500">Up to 35%</td>
                <td class="px-4 py-3 text-gray-500">20%</td>
                <td class="px-4 py-3 text-gray-500">0%</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-medium text-gray-700">WhatsApp native</td>
                <td class="px-4 py-3 text-emerald-700">Yes</td>
                <td class="px-4 py-3 text-gray-500">No</td>
                <td class="px-4 py-3 text-gray-500">No</td>
                <td class="px-4 py-3 text-gray-500">No</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-medium text-gray-700">App download required</td>
                <td class="px-4 py-3 text-emerald-700">No</td>
                <td class="px-4 py-3 text-gray-500">Yes</td>
                <td class="px-4 py-3 text-gray-500">Yes</td>
                <td class="px-4 py-3 text-gray-500">Yes</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-medium text-gray-700">Monthly price</td>
                <td class="px-4 py-3 font-bold text-emerald-700">From EUR 49</td>
                <td class="px-4 py-3 text-gray-500">Free + commission</td>
                <td class="px-4 py-3 text-gray-500">Free + commission</td>
                <td class="px-4 py-3 text-gray-500">From EUR 30</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</Layout>
